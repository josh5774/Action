{
  "name": "filmlink",
  "private": true,
  "version": "0.2.0",
  "workspaces": [
    "backend",
    "web",
    "mobile",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel --filter=@filmlink/backend --filter=@filmlink/web",
    "build": "turbo run build --filter=@filmlink/web",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.4.4"
  }
}
